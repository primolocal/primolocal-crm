# Environment Variables for PrimoLocal CRM
# Copy this file to .env.local and fill in your actual values

# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Discord Webhook (Optional — for application notifications)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Email SMTP (Required for application email notifications)
# For Google Workspace: smtp.gmail.com, port 587
# Generate an App Password at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tommy@primolocal.org
SMTP_PASS=your-app-password
NOTIFY_EMAIL=tommy@primolocal.org

# Next.js (Optional — defaults to 3000)
PORT=3000
